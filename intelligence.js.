window.CellScopeIntel = {


    /*
    Break phone number into components
    */

    dissect(phone){

        return {

            countryCode:
                phone.countryCallingCode || null,

            nationalNumber:
                phone.nationalNumber || null,

            country:
                phone.country || null,

            raw:
                phone.number || null

        };

    },


    /*
    Determine confidence level
    */

    confidence(source){

        const levels = {

            verified:{
                label:"Verified",
                icon:"🟢"
            },

            inferred:{
                label:"Public Metadata",
                icon:"🟡"
            },

            unknown:{
                label:"Unknown",
                icon:"⚪"
            }

        };


        return levels[source] || levels.unknown;

    },


    /*
    Create human-readable summary
    */

    summary(data){

        let output=[];


        if(data.valid){

            output.push(
                "Valid phone number format detected."
            );

        }


        if(data.country){

            output.push(
                `Number belongs to ${data.country}.`
            );

        }


        if(data.region){

            output.push(
                `Associated region: ${data.region}.`
            );

        }


        if(data.timezone){

            output.push(
                `Timezone: ${data.timezone}.`
            );

        }


        if(data.type){

            output.push(
                `Detected type: ${data.type}.`
            );

        }


        return output;

    },


    /*
    Explain fields
    */

    explanations:{


        areaCode:

        {
            title:"Area Code",

            text:
            "The area code identifies a geographic numbering region in systems such as NANP."
        },


        e164:

        {
            title:"E.164",

            text:
            "The international telephone format standardized by the ITU."
        },


        carrier:

        {
            title:"Carrier",

            text:
            "Carrier information may represent original assignment and can change through number portability."
        },


        timezone:

        {
            title:"Timezone",

            text:
            "The likely timezone associated with the numbering region."
        }


    },


    /*
    Generate complete intelligence object
    */

    analyze(phone){


        const parts=this.dissect(phone);


        return {

            parts,


            confidence:this.confidence(
                "verified"
            ),


            generated:new Date()
                .toISOString()

        };


    }


};


